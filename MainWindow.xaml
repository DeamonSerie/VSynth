<Window x:Class="VSynthApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:VSynthApp"
        mc:Ignorable="d"
        Title="VSynth - Vocaloid Style Studio" Height="700" Width="1000"
        Background="#121212" Foreground="White" FontFamily="Outfit, Segoe UI">
    <Window.Resources>
        <!-- osu!lazer inspired Palette -->
        <Color x:Key="OsuPinkColor">#FF66AA</Color>
        <Color x:Key="OsuPurpleColor">#8855FF</Color>
        <Color x:Key="OsuDarkColor">#222228</Color>
        <Color x:Key="OsuPanelColor">#303038</Color>
        
        <SolidColorBrush x:Key="OsuPink" Color="{StaticResource OsuPinkColor}"/>
        <SolidColorBrush x:Key="OsuPurple" Color="{StaticResource OsuPurpleColor}"/>
        <SolidColorBrush x:Key="OsuDark" Color="{StaticResource OsuDarkColor}"/>
        <SolidColorBrush x:Key="OsuPanel" Color="{StaticResource OsuPanelColor}"/>

        <Style x:Key="HeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28"/>
            <Setter Property="FontWeight" Value="ExtraBold"/>
            <Setter Property="Margin" Value="20,10"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="{StaticResource OsuPinkColor}"/>
                </Setter.Value>
            </Setter>
        </Style>
        
        <Style x:Key="GummyButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource OsuPanel}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="Margin" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" 
                                CornerRadius="15" Padding="{TemplateBinding Padding}">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.Effect>
                                    <DropShadowEffect BlurRadius="5" ShadowDepth="1" Opacity="0.3"/>
                                </ContentPresenter.Effect>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#404048"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource OsuPink}"/>
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="0.9" Duration="0:0:0.05"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="0.9" Duration="0:0:0.05"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.05" Duration="0:0:0.1"/>
                                            <DoubleAnimation Storyboard.TargetName="border" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.05" Duration="0:0:0.1"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowLabelStyle" TargetType="TextBlock">
            <Setter Property="Width" Value="60"/>
            <Setter Property="Height" Value="60"/>
            <Setter Property="TextAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="22"/>
            <Setter Property="FontWeight" Value="Black"/>
            <Setter Property="Foreground" Value="{StaticResource OsuPink}"/>
            <Setter Property="Background" Value="{StaticResource OsuDark}"/>
            <Setter Property="Margin" Value="0,2"/>
        </Style>

        <Style x:Key="FlatCombo" TargetType="ComboBox">
            <Setter Property="Background" Value="#202025"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="5,2"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                            <Grid>
                                <ToggleButton Name="ToggleButton" Background="Transparent" BorderThickness="0" HorizontalContentAlignment="Stretch" VerticalContentAlignment="Center">
                                    <ContentPresenter Margin="5,0" HorizontalAlignment="Left" VerticalAlignment="Center" Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"/>
                                </ToggleButton>
                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Border Name="DropDownBorder" Background="{StaticResource OsuPanel}" CornerRadius="8" BorderThickness="1" BorderBrush="#444" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                                            <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Grid Background="{StaticResource OsuDark}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Border Grid.Row="0" Background="{StaticResource OsuPanel}" CornerRadius="0,0,20,20" Margin="0,0,0,10" Padding="10">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="2" Opacity="0.5"/>
            </Border.Effect>
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="VSYNTH" Style="{StaticResource HeaderStyle}" VerticalAlignment="Center"/>
                <Button Content="Record" Style="{StaticResource GummyButtonStyle}" Command="{Binding RecordCommand}"/>
                <Button Content="Clear" Style="{StaticResource GummyButtonStyle}" Command="{Binding ClearCommand}"/>
                <Button Content="Save" Style="{StaticResource GummyButtonStyle}" Command="{Binding SaveCommand}"/>
                <Button Content="Load" Style="{StaticResource GummyButtonStyle}" Command="{Binding LoadCommand}"/>
                <Button Content="Export MP3" Style="{StaticResource GummyButtonStyle}" Command="{Binding ExportCommand}"/>
                <Button Content="Play" Style="{StaticResource GummyButtonStyle}" Command="{Binding PlayCommand}" Background="{StaticResource OsuPink}"/>
            </StackPanel>
        </Border>

        <!-- Main Sequencer -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Grid Name="SequencerGrid" Background="#18181F">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/> <!-- Row Labels -->
                    <ColumnDefinition Width="*"/>    <!-- Blocks Area -->
                </Grid.ColumnDefinitions>
                
                <!-- Row Labels A-G -->
                <StackPanel Grid.Column="0" Background="{StaticResource OsuDark}">
                    <TextBlock Text="G" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="F" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="E" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="D" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="C" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="B" Style="{StaticResource RowLabelStyle}"/>
                    <TextBlock Text="A" Style="{StaticResource RowLabelStyle}"/>
                </StackPanel>

                <!-- Grid Area -->
                <ItemsControl Grid.Column="1" ItemsSource="{Binding Blocks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas Width="2000" Height="450" Background="#121218" MouseDown="Canvas_MouseDown">
                                <!-- Grid Lines -->
                                <Canvas.CacheMode>
                                    <BitmapCache/>
                                </Canvas.CacheMode>
                            </Canvas>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}"/>
                            <Setter Property="Canvas.Top" Value="{Binding Y}"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="BlockBorder" Width="140" Height="65" Background="{StaticResource OsuPanel}" CornerRadius="18" BorderThickness="3" BorderBrush="{StaticResource OsuPurple}" Margin="2" RenderTransformOrigin="0.5,0.5"
                                    MouseLeftButtonDown="Block_MouseLeftButtonDown"
                                    MouseMove="Block_MouseMove"
                                    MouseLeftButtonUp="Block_MouseLeftButtonUp">
                                <Border.InputBindings>
                                    <MouseBinding MouseAction="RightClick" 
                                                  Command="{Binding DataContext.RemoveBlockCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" 
                                                  CommandParameter="{Binding}"/>
                                </Border.InputBindings>
                                <Border.RenderTransform>
                                    <ScaleTransform ScaleX="1" ScaleY="1"/>
                                </Border.RenderTransform>
                                <Border.Effect>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.4"/>
                                </Border.Effect>
                                <Grid Margin="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="*"/>
                                        <RowDefinition Height="*"/>
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Modifier Dropdown -->
                                    <ComboBox Grid.Row="0" Grid.Column="0" ItemsSource="{Binding Modifiers}" SelectedItem="{Binding SelectedModifier}" 
                                              Style="{StaticResource FlatCombo}"/>
                                    
                                    <!-- Chord Type Dropdown -->
                                    <ComboBox Grid.Row="0" Grid.Column="1" ItemsSource="{Binding ChordTypes}" SelectedItem="{Binding SelectedChordType}" 
                                              Style="{StaticResource FlatCombo}"/>

                                    <!-- Voice Content (Letter/Word) -->
                                    <Border Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Background="#202025" CornerRadius="8" Margin="2">
                                        <TextBox Text="{Binding SelectedVoice, UpdateSourceTrigger=PropertyChanged}" 
                                                 Background="Transparent" Foreground="White" BorderThickness="0" FontSize="11" Padding="5,2" VerticalContentAlignment="Center" 
                                                 CaretBrush="White"/>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BlockBorder" Property="BorderBrush" Value="{StaticResource OsuPink}"/>
                                    <Trigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BlockBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1.1" Duration="0:0:0.1"/>
                                                <DoubleAnimation Storyboard.TargetName="BlockBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1.1" Duration="0:0:0.1"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.EnterActions>
                                    <Trigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetName="BlockBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)" To="1" Duration="0:0:0.2"/>
                                                <DoubleAnimation Storyboard.TargetName="BlockBorder" Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)" To="1" Duration="0:0:0.2"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </Trigger.ExitActions>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
                
                <Canvas Grid.Column="1" IsHitTestVisible="False">
                    <Line x:Name="PlayheadLine" X1="{Binding PlayheadX}" Y1="0" X2="{Binding PlayheadX}" Y2="2000" 
                          Stroke="{StaticResource OsuPink}" StrokeThickness="4" 
                          Visibility="{Binding IsPlaying, Converter={StaticResource BoolToVis}}">
                        <Line.Effect>
                            <DropShadowEffect Color="{StaticResource OsuPinkColor}" BlurRadius="10" ShadowDepth="0"/>
                        </Line.Effect>
                    </Line>
                </Canvas>
            </Grid>
        </ScrollViewer>

        <!-- Status Bar -->
        <StatusBar Grid.Row="2" Background="{StaticResource OsuDark}" Foreground="#888">
            <TextBlock Text="{Binding StatusText}" Margin="20,5"/>
        </StatusBar>
    </Grid>

</Window>
